rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.className is string &&
             data.guardians is list &&
             data.createdAt is number;
    }

    match /students/{studentId} {
      // Permitindo leitura e escrita pública conforme solicitado pelo usuário
      allow read, write: if true;
      
      allow create, update: if isValidStudent(request.resource.data);
    }
  }
}
